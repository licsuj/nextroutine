{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(self)"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://*.kit.com https://*.ck.page; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.kit.com https://*.ck.page; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://api.convertkit.com https://*.kit.com https://*.ck.page https://buy.stripe.com; frame-src https://js.stripe.com https://*.kit.com https://*.ck.page; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://api.convertkit.com https://*.kit.com https://*.ck.page;"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    }
  ],
  "redirects": [
    { "source": "/dad",            "destination": "/new-dad",         "permanent": true },
    { "source": "/sleep",          "destination": "/sleep-better",    "permanent": true },
    { "source": "/morning",        "destination": "/morning-routine", "permanent": true },
    { "source": "/screen",         "destination": "/screen-time",     "permanent": true },
    { "source": "/subscribe",      "destination": "/newsletter",      "permanent": true },
    { "source": "/pro",            "destination": "/pricing",         "permanent": false }
  ],
  "rewrites": [
    { "source": "/blog",          "destination": "/blog/index.html" },
    { "source": "/api/subscribe", "destination": "/api/subscribe" },
    { "source": "/api/webhook",   "destination": "/api/webhook" }
  ]
}
