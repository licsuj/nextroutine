{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://*.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    }
  ],
  "redirects": [
    { "source": "/dad",            "destination": "/new-dad",         "permanent": true },
    { "source": "/sleep",          "destination": "/sleep-better",    "permanent": true },
    { "source": "/morning",        "destination": "/morning-routine", "permanent": true },
    { "source": "/screen",         "destination": "/screen-time",     "permanent": true },
    { "source": "/subscribe",      "destination": "/newsletter",      "permanent": true },
    { "source": "/pro",            "destination": "/pricing",         "permanent": false },
    { "source": "/blog/newborn-tips-for-dads",           "destination": "/blog/newborn-week-1-dad-guide",      "permanent": true },
    { "source": "/blog/how-to-support-pregnant-partner", "destination": "/blog/pregnancy-dad-next-steps",      "permanent": true },
    { "source": "/blog/first-time-dad-checklist",        "destination": "/blog/how-to-prepare-for-fatherhood", "permanent": true },
    { "source": "/blog/pregnancy-guide-for-dads",        "destination": "/blog/pregnancy-dad-next-steps",      "permanent": true },
    { "source": "/blog/template",                        "destination": "/blog/morning-routine-new-dad",       "permanent": true }
  ],
  "rewrites": [
    { "source": "/blog",          "destination": "/blog/index.html" },
    { "source": "/api/subscribe", "destination": "/api/subscribe" },
    { "source": "/api/webhook",   "destination": "/api/webhook" }
  ]
}
